# ─────────────────────────────────────────────────────────
# LendChain Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # Set to "production" on server

# ── MongoDB ───────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lendchain?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173   # Change to your deployed frontend URL in production

# ── Blockchain (Sepolia) ──────────────────────────────────
# Infura:   https://app.infura.io  → New Project → Sepolia endpoint
# Alchemy:  https://dashboard.alchemy.com → Create App → Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Deployed contract address (from: cd blockchain && npm run deploy:sepolia)
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# ── Email — Brevo (Sendinblue) ────────────────────────────
# Sign up free at https://app.brevo.com
# API key:     Settings → SMTP & API → API Keys → Generate
# Sender email: must be a verified sender in Brevo dashboard
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=LendChain
