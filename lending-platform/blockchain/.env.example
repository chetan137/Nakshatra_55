# ─────────────────────────────────────────────────────────────
# Sepolia Testnet (get free ETH at https://sepoliafaucet.com)
# ─────────────────────────────────────────────────────────────

# Infura RPC URL — https://app.infura.io → create project → copy Sepolia URL
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Your MetaMask wallet private key (NEVER commit real key — use a test wallet!)
# Export from MetaMask: Account → 3 dots → Account Details → Show Private Key
PRIVATE_KEY=your_metamask_test_wallet_private_key_here

# Etherscan API key (optional — for contract verification)
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
