# ─────────────────────────────────────────────────────────
# LendChain Frontend — Environment Variables
# Copy this file to .env and fill in all values.
# All variables MUST start with VITE_ to be exposed to the browser.
# NEVER put secrets here — these values are bundled into the client JS.
# ─────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────
# Development:  http://localhost:5000/api
# Production:   https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# ── Smart Contract ────────────────────────────────────────
# Deployed contract address (from: cd blockchain && npm run deploy:sepolia)
# Must match CONTRACT_ADDRESS in backend/.env
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere
